# === REQUIRED ===

# OpenAI API key — for query normalization and ingredient parsing
# Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# === SEARCH PROVIDER ===

# Serper.dev API key — REQUIRED for the buying engine (/api/decide).
# The buying engine uses Serper's /shopping endpoint to pull buyable offers;
# Brave has no shopping API, so Serper must be set for /api/decide to work.
# Get one at: https://serper.dev (2,500 free queries)
SERPER_API_KEY=...

# Brave Search API key — OPTIONAL. Only used by the legacy recipe endpoints
# (/api/search, /api/plan-week, /api/trending) as the preferred web-search
# provider. Not required for the buying engine.
# Get one at: https://api.search.brave.com/ (2,000 free queries/month, no credit card)
BRAVE_API_KEY=...

# === OPTIONAL ===

# Port to listen on (Railway sets this automatically)
PORT=3000

# LLM model — default is gpt-4o-mini (cheap and fast)
OPENAI_MODEL=gpt-4o-mini

# Cache TTL in seconds (how long to cache search results)
CACHE_TTL_SECONDS=3600

# Max candidate URLs to fetch per search
MAX_CANDIDATES=6

# Final results returned per query
RESULTS_PER_QUERY=3
